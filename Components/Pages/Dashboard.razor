@page "/dashboard"
@using Microsoft.AspNetCore.Authorization
@attribute [Authorize]
@rendermode InteractiveServer

@using GymTracker.Data
@using GymTracker.Models
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.AspNetCore.Components
@using Microsoft.EntityFrameworkCore
@using System.Linq
@using System.Globalization

@inject AuthenticationStateProvider AuthStateProvider
@inject ApplicationDbContext db
@inject UserManager<ApplicationUser> userManager
@inject NavigationManager nav
@inject IJSRuntime JS

<h1>My workouts</h1>

@if (showModal && created.HasValue)
{
    <div class="modal-overlay">
        <div class="modal">
            <h2>Workout created!</h2>
            <p>Great job! Let's add some exercises and reps.</p>

            <button class="add-btn" @onclick="GoToWorkout">
                Add exercises
            </button>

            <button class="undo-btn" @onclick="CloseModal">
                Maybe later
            </button>
        </div>
    </div>
}

@if (workouts != null)
{
    <!-- Statistik -->
    <div class="stats-grid">

        <div class="stat-card">
            <h3>@totalWorkouts</h3>
            <p>Workouts</p>
        </div>

        <div class="stat-card">
            <h3>@totalExercises</h3>
            <p>Exercises</p>
        </div>

        <div class="stat-card">
            <h3>@totalSets</h3>
            <p>Sets logged</p>
        </div>

        <div class="stat-card">
            <h3>@totalVolume</h3>
            <p>Total volume</p>
        </div>

        <div class="stat-card">
            <h3>@weeklyFrequency.ToString("0.0")</h3>
            <p>Workouts / week</p>
        </div>

    </div>
}

<div class="buttondiv">
    <button class="add-btn" type="button" @onclick="GoCreate">Create workout</button>
</div>

@if (workouts != null && workouts.Any())
{
    <!-- Graf: antal pass per vecka -->
    <div class="chart-card">

        <h3>Workouts per week</h3>

        <canvas id="progressChart"></canvas>

    </div>
}

<!-- Filter och sökruta bredvid varandra -->
<div class="filter-bar">

    <select value="@selectedFilter" @onchange="ApplyFilter">
        <option value="all">All time</option>
        <option value="7">Last 7 days</option>
        <option value="30">Last 30 days</option>
        <option value="year">This year</option>
    </select>

    <!-- Sökruta – listan filtreras vid varje knapptryckning -->
    <input type="text" placeholder="Search workouts..." value="@searchQuery" @oninput="OnSearchInput"
           class="search-input" />

</div>

@if (workouts == null)
{
    <p>Loading workouts...</p>
}
else if (!FilteredWorkouts.Any())
{
    <p>No workouts found.</p>
}
else
{
    <ul>
        @foreach (var w in FilteredWorkouts)
        {
            <li>
                <a href="/workout/@w.Id">
                    <b>@w.Title</b> (@w.Date.ToShortDateString())
                </a>

                <div class="actions">
                    <button class="add-btn small" @onclick="() => GoToWorkout(w.Id)">
                        Add exercises
                    </button>

                    <button class="undo-btn" @onclick="() => DeleteWorkout(w.Id)">
                        Delete
                    </button>
                </div>
            </li>
        }
    </ul>
}

@code {

    [Parameter]
    [SupplyParameterFromQuery]
    public int? created { get; set; }

    bool showModal = false;

    List<WorkoutSession>? workouts;

    // Variabler för statistik
    int totalWorkouts;
    int totalExercises;
    int totalSets;
    double totalVolume;
    double weeklyFrequency;

    // Variabel för filtrering
    string selectedFilter = "all";

    // Sökfråga – filtrerar listan i realtid
    string searchQuery = "";

    // Returnerar filtrerad lista baserat på sökfrågan
    IEnumerable<WorkoutSession> FilteredWorkouts =>
        workouts?.Where(w =>
            string.IsNullOrWhiteSpace(searchQuery) ||
            w.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase)
        ) ?? Enumerable.Empty<WorkoutSession>();

    // Datan till chart.js
    List<string> chartLabels = new();
    List<double> chartData = new();

    bool chartRendered = false;

    protected override async Task OnInitializedAsync()
    {
        // Ladda workouts via filtermetoden
        await LoadWorkouts();

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = await userManager.GetUserAsync(authState.User);

        // Hämta alla sets
        var sets = db.Sets
            .Include(s => s.WorkoutExercise)
            .ThenInclude(we => we.WorkoutSession)
            .Where(s => s.WorkoutExercise.WorkoutSession.UserId == user!.Id)
            .ToList();

        // Grupp för grafen: antal workouts per vecka
        var weeklyWorkouts = workouts!
            .GroupBy(w =>
            {
                return new
                {
                    Year = w.Date.Year,
                    Week = ISOWeek.GetWeekOfYear(w.Date)
                };
            })
            .OrderBy(g => g.Key.Year)
            .ThenBy(g => g.Key.Week);

        foreach (var g in weeklyWorkouts)
        {
            chartLabels.Add($"W{g.Key.Week} {g.Key.Year}");
            chartData.Add(g.Count());
        }

        // Statistik
        totalSets = sets.Count;
        totalVolume = sets.Sum(s => s.Reps * s.Weight);
        totalWorkouts = workouts!.Count;

        totalExercises = db.WorkoutExercises
        .Include(we => we.WorkoutSession)
        .Where(we => we.WorkoutSession.UserId == user.Id && !we.WorkoutSession.IsTemplate)
        .Count();

        // Beräkna träningsfrekvens
        if (workouts.Any())
        {
            var firstWorkout = workouts.Min(w => w.Date);
            var lastWorkout = workouts.Max(w => w.Date);

            var totalDays = (lastWorkout - firstWorkout).TotalDays;
            var weeks = totalDays / 7;

            if (weeks < 1) weeks = 1;

            weeklyFrequency = workouts.Count / weeks;
        }

        if (created.HasValue)
            showModal = true;
    }

    // Uppdaterar sökfrågan vid varje knapptryckning
    void OnSearchInput(ChangeEventArgs e)
    {
        searchQuery = e.Value?.ToString() ?? "";
    }

    // Metod för att ladda workouts med filtrering
    async Task LoadWorkouts()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = await userManager.GetUserAsync(authState.User);

        var query = db.WorkoutSessions
            .Where(w => w.UserId == user!.Id && !w.IsTemplate);

        if (selectedFilter == "7")
            query = query.Where(w => w.Date >= DateTime.Today.AddDays(-7));

        else if (selectedFilter == "30")
            query = query.Where(w => w.Date >= DateTime.Today.AddDays(-30));

        else if (selectedFilter == "year")
            query = query.Where(w => w.Date.Year == DateTime.Today.Year);

        workouts = query
            .OrderByDescending(w => w.Date)
            .ToList();
    }

    void GoCreate()
    {
        nav.NavigateTo("/create-workout");
    }

    void GoToWorkout()
    {
        nav.NavigateTo($"/workout/{created}");
    }

    void GoToWorkout(int id)
    {
        nav.NavigateTo($"/workout/{id}");
    }

    void CloseModal()
    {
        showModal = false;
    }

    async Task DeleteWorkout(int id)
    {
        var workout = db.WorkoutSessions.FirstOrDefault(x => x.Id == id);

        if (workout != null)
        {
            db.WorkoutSessions.Remove(workout);
            await db.SaveChangesAsync();
        }

        await LoadWorkouts();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!chartRendered && chartData.Count > 0)
        {
            chartRendered = true;

            await JS.InvokeVoidAsync("renderProgressChart", chartLabels, chartData);
        }
    }

    async Task ApplyFilter(ChangeEventArgs e)
    {
        selectedFilter = e.Value?.ToString() ?? "all";

        await LoadWorkouts();
    }

}
