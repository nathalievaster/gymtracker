@page "/exercises"
@attribute [Authorize]
@rendermode InteractiveServer

@using GymTracker.Data
@using GymTracker.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore

@inject ApplicationDbContext db
@inject UserManager<ApplicationUser> userManager
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS

<div class="exercise-page">

    <!-- SIDEBAR -->
    <aside class="sidebar">

        <h1>Exercise library</h1>

        <hr class="sidebar-divider" />

        <span class="ex-section-label">Global exercises</span>

        @if (!globalExercises.Any())
        {
            <p class="empty">No global exercises</p>
        }
        else
        {
            <div class="ex-list">
                @foreach (var ex in globalExercises)
                {
                    <div class="ex-item">
                        <span>@ex.Name</span>
                        @if (isAdmin)
                        {
                            <button class="undo-btn" @onclick="() => DeleteGlobal(ex.Id)">Delete</button>
                        }
                    </div>
                }
            </div>
        }

        <hr class="sidebar-divider" />

        <span class="ex-section-label">My exercises</span>

        @if (!myExercises.Any())
        {
            <p class="empty">No personal exercises</p>
        }
        else
        {
            <div class="ex-list">
                @foreach (var ex in myExercises)
                {
                    <div class="ex-item">
                        <span>@ex.Name</span>
                        <button class="undo-btn small" @onclick="() => DeletePersonal(ex.Id)">Delete</button>
                    </div>
                }
            </div>
        }

    </aside>

    <!-- MAIN CONTENT -->
    <main class="exercise-main">

        <!-- Progression – kollapsbar -->
        <div class="progression-toggle" @onclick="ToggleProgression">
            <div class="progression-toggle-left">
                <span class="progression-title">Track progression</span>
                <span class="progression-sub">Select an exercise to view your progress chart</span>
            </div>
            <span class="progression-chevron @(showProgression ? "open" : "")">▼</span>
        </div>

        @if (showProgression)
        {
            <div class="chart-card">
                <div class="chart-header">
                    <h3>Progression</h3>
                    <select value="@selectedExerciseId" @onchange="OnExerciseSelected">
                        <option value="0">Select exercise...</option>
                        @foreach (var ex in allExercisesForChart)
                        {
                            <option value="@ex.Id">@ex.Name</option>
                        }
                    </select>
                </div>

                @if (chartHasData)
                {
                    <div class="chart-canvas-wrapper">
                        <canvas id="progressionChart"></canvas>
                    </div>
                }
                else if (selectedExerciseId != 0)
                {
                    <p class="empty">No data yet for this exercise.</p>
                }
            </div>
        }

        <!-- Skapa-formulär -->
        <div class="create-grid">

            @if (isAdmin)
            {
                <section class="card">
                    <span class="admin-badge">Admin only</span>
                    <h3>Create global exercise</h3>
                    <input placeholder="Exercise name" @bind="globalName" />
                    <textarea placeholder="Description" @bind="globalDescription"></textarea>
                    <button class="add-btn" @onclick="CreateGlobalExercise">Create global</button>
                    @if (!string.IsNullOrEmpty(globalMessage))
                    {
                        <p class="message">@globalMessage</p>
                    }
                </section>
            }

            <section class="card">
                <h3>Create personal exercise</h3>
                <input placeholder="Exercise name" @bind="personalName" />
                <textarea placeholder="Description" @bind="personalDescription"></textarea>
                <button class="add-btn" @onclick="CreatePersonalExercise">Create personal</button>
                @if (!string.IsNullOrEmpty(personalMessage))
                {
                    <p class="message">@personalMessage</p>
                }
            </section>

        </div>

    </main>

</div>

@code {
    bool showProgression = false;

    void ToggleProgression()
    {
        showProgression = !showProgression;
    }

    List<Exercise> globalExercises = new();
    List<Exercise> myExercises = new();

    // Alla övningar användaren har loggat – visas i graf-dropdown
    List<Exercise> allExercisesForChart = new();

    string globalName = "";
    string globalDescription = "";

    string personalName = "";
    string personalDescription = "";

    // Variabler för meddelanden på olika kort
    string personalMessage = "";
    string globalMessage = "";

    ApplicationUser? user;
    bool isAdmin = false;

    // Variabler för progressionsgrafen
    int selectedExerciseId = 0;
    bool chartHasData = false;


    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        user = await userManager.GetUserAsync(auth.User);

        isAdmin = await userManager.IsInRoleAsync(user!, "Admin");

        await LoadExercises();
        await LoadChartExercises();
    }

    // Hämtar alla övningar användaren faktiskt har loggat sets på
    async Task LoadChartExercises()
    {
        var loggedExerciseIds = await db.Sets
            .Include(s => s.WorkoutExercise)
            .ThenInclude(we => we.WorkoutSession)
            .Where(s => s.WorkoutExercise.WorkoutSession.UserId == user!.Id)
            .Select(s => s.WorkoutExercise.ExerciseId)
            .Distinct()
            .ToListAsync();

        allExercisesForChart = await db.Exercises
            .Where(e => loggedExerciseIds.Contains(e.Id))
            .OrderBy(e => e.Name)
            .ToListAsync();
    }

    // Körs när användaren väljer en övning i dropdown
    async Task OnExerciseSelected(ChangeEventArgs e)
    {
        selectedExerciseId = int.Parse(e.Value?.ToString() ?? "0");
        chartHasData = false;

        if (selectedExerciseId == 0) return;

        // Hämta alla sets för vald övning, gruppera per datum och ta maxvikt per pass
        var data = await db.Sets
            .Include(s => s.WorkoutExercise)
            .ThenInclude(we => we.WorkoutSession)
            .Where(s =>
                s.WorkoutExercise.WorkoutSession.UserId == user!.Id &&
                s.WorkoutExercise.ExerciseId == selectedExerciseId)
            .ToListAsync();

        if (!data.Any()) return;

        // Gruppera per datum, ta maxvikt per pass
        var grouped = data
            .GroupBy(s => s.WorkoutExercise.WorkoutSession.Date.Date)
            .OrderBy(g => g.Key)
            .ToList();

        var labels = grouped.Select(g => g.Key.ToShortDateString()).ToList();
        var values = grouped.Select(g => g.Max(s => s.Weight)).ToList();

        chartHasData = true;

        // StateHasChanged behövs så att canvas renderas innan JS anropas
        StateHasChanged();

        await Task.Delay(50);

        await JS.InvokeVoidAsync("renderProgressionChart", labels, values);
    }


    async Task LoadExercises()
    {
        globalExercises = await db.Exercises
            .Where(e => e.IsGlobal)
            .OrderBy(e => e.Name)
            .ToListAsync();

        myExercises = await db.Exercises
            .Where(e => !e.IsGlobal && e.OwnerId == user!.Id)
            .OrderBy(e => e.Name)
            .ToListAsync();
    }

    async Task CreateGlobalExercise()
    {
        if (!isAdmin) return;

        if (string.IsNullOrWhiteSpace(globalName))
        {
            globalMessage = "Name required";
            return;
        }

        var exists = await db.Exercises.AnyAsync(e => e.Name.ToLower() == globalName.ToLower());
        if (exists)
        {
            globalMessage = "Exercise already exists";
            return;
        }

        db.Exercises.Add(new Exercise
        {
            Name = globalName.Trim(),
            Description = globalDescription,
            IsGlobal = true
        });

        await db.SaveChangesAsync();

        globalName = "";
        globalDescription = "";
        globalMessage = "Global exercise created";

        await LoadExercises();
    }

    async Task CreatePersonalExercise()
    {
        if (string.IsNullOrWhiteSpace(personalName))
        {
            personalMessage = "Name required";
            return;
        }

        db.Exercises.Add(new Exercise
        {
            Name = personalName.Trim(),
            Description = personalDescription,
            OwnerId = user!.Id,
            IsGlobal = false
        });

        await db.SaveChangesAsync();

        personalName = "";
        personalDescription = "";
        personalMessage = "Personal exercise created";

        await LoadExercises();
    }

    async Task DeleteGlobal(int id)
    {
        if (!isAdmin) return;

        var used = await db.WorkoutExercises.AnyAsync(w => w.ExerciseId == id);
        if (used)
        {
            personalMessage = "Cannot delete. Used in workouts.";
            return;
        }

        var ex = await db.Exercises.FirstOrDefaultAsync(e => e.Id == id && e.IsGlobal);
        if (ex == null) return;

        db.Exercises.Remove(ex);
        await db.SaveChangesAsync();

        await LoadExercises();
    }

    async Task DeletePersonal(int id)
    {
        var ex = await db.Exercises.FirstOrDefaultAsync(e => e.Id == id && e.OwnerId == user!.Id);
        if (ex == null) return;

        var used = await db.WorkoutExercises.AnyAsync(w => w.ExerciseId == id);
        if (used)
        {
            personalMessage = "Cannot delete. Used in workouts.";
            return;
        }

        db.Exercises.Remove(ex);
        await db.SaveChangesAsync();

        await LoadExercises();
    }
}
