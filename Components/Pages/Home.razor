@page "/"
@rendermode InteractiveServer

<PageTitle>Home</PageTitle>

<section class="landing">

    <section class="intro">

        <h2>Train smarter with GymTracker</h2>

        <p>
            GymTracker helps you track your workouts, log exercises,
            and measure your progress over time. Stay consistent and
            make sure you are applying progressive overload in every session.
        </p>

        <div class="cta-buttons">
            <a class="first-btn" href="/create-workout">Start a workout</a>
            <a class="secondary-btn" href="/dashboard">View workouts</a>
        </div>

    </section>


    <section class="features">

        <h2>Why track your workouts?</h2>

        <div class="feature-grid">

            <div class="feature-card">
                <h3>Track every set</h3>
                <p>
                    Log reps and weight for each exercise so you always
                    know what you lifted last time.
                </p>
            </div>

            <div class="feature-card">
                <h3>Progressive overload</h3>
                <p>
                    Easily see your previous workouts and make sure
                    you increase weight, reps, or intensity over time.
                </p>
            </div>

            <div class="feature-card">
                <h3>Build your exercise library</h3>
                <p>
                    Create your own personal exercises and reuse them
                    across workouts.
                </p>
            </div>

        </div>

    </section>


    <section class="how">

        <h2>How it works</h2>

        <div class="steps">

            <div class="step">
                <span>1</span>
                <h4>Create a workout</h4>
                <p>Start a new training session and give it a title.</p>
            </div>

            <div class="step">
                <span>2</span>
                <h4>Add exercises</h4>
                <p>Select or create exercises for your workout.</p>
            </div>

            <div class="step">
                <span>3</span>
                <h4>Log your sets</h4>
                <p>Track reps and weight for each set.</p>
            </div>

        </div>

    </section>

</section>