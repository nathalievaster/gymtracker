@page "/templates"
@attribute [Authorize]
@rendermode InteractiveServer

@using GymTracker.Data
@using GymTracker.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore

@inject ApplicationDbContext db
@inject UserManager<ApplicationUser> userManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager nav

<h1>Templates</h1>

<!-- Skapa ny mall -->
<div class="card">
    <h3>Create new template</h3>
    <div class="form-group">
        <input placeholder="Template name, e.g. Push day..." @bind="newTemplateName" />
    </div>
    <button class="add-btn" @onclick="CreateTemplate">Create</button>
    @if (!string.IsNullOrEmpty(createMessage))
    {
        <p class="message">@createMessage</p>
    }
</div>

<!-- Lista alla mallar -->
@if (templates == null)
{
    <p>Loading...</p>
}
else if (!templates.Any())
{
    <p class="empty">No templates yet.</p>
}
else
{
    @foreach (var t in templates)
    {
        <div class="exercise-card">
            <!-- Mall-header med namn, use och delete -->
            <div class="exercise-header">
                <h5>
                    @t.Title
                    <span class="template-badge">Template</span>
                </h5>
                <div style="display:flex; gap:6px;">
                    <button class="add-btn small" @onclick="() => UseTemplate(t.Id)">
                        Use template
                    </button>
                    <button class="undo-btn small" @onclick="() => DeleteTemplate(t.Id)">
                        Delete
                    </button>
                </div>
            </div>

            <!-- Lista övningar i mallen -->
            @if (t.WorkoutExercises == null || !t.WorkoutExercises.Any())
            {
                <p class="empty">No exercises yet</p>
            }
            else
            {
                <table class="sets-table">
                    <thead>
                        <tr>
                            <th>Exercise</th>
                            <th></th>
                        </tr>
                    </thead>

                    <tbody>
                        @foreach (var we in t.WorkoutExercises ?? new List<WorkoutExercise>())
                        {
                            <tr>
                                <td>@we.Exercise?.Name</td>
                                <td>
                                    <button class="undo-btn small" @onclick="() => RemoveExerciseFromTemplate(we.Id, t.Id)">
                                        Remove
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            <!-- Knapp för att lägga till övning i denna mall -->
            <button class="add-btn small" @onclick="() => OpenExerciseModal(t.Id)">
                Add exercise
            </button>

        </div>
    }
}

<!-- Modal för att lägga till övning i en mall -->
@if (showExerciseModal)
{
    <div class="modal-overlay">
        <div class="modal">

            <h3>Add exercise</h3>

            <input type="text" placeholder="Search exercises..." value="@exerciseSearch" @oninput="OnExerciseSearch"
                   class="search-input" />

            @if (!string.IsNullOrWhiteSpace(exerciseSearch))
            {
                <div class="exercise-search-results">
                    @foreach (var ex in allExercises.Where(e =>
                                            e.Name.Contains(exerciseSearch, StringComparison.OrdinalIgnoreCase)))
                    {
                        <div class="exercise-search-item @(selectedExerciseIds.Contains(ex.Id) ? "selected" : "")"
                             @onclick="() => SelectExercise(ex)">
                            <span class="exercise-check">@(selectedExerciseIds.Contains(ex.Id) ? "✓" : "")</span>
                            @ex.Name
                        </div>
                    }
                </div>
            }

            @if (selectedExercises != null && selectedExercises.Any())
            {
                <div class="selected-chips">
                    @foreach (var kvp in selectedExercises)
                    {
                        <span class="chip">
                            @kvp.Value
                            <button
                            @onclick="() => { selectedExerciseIds.Remove(kvp.Key); selectedExercises.Remove(kvp.Key); }">×</button>
                        </span>
                    }
                </div>
            }

            <b>or create new</b>
            <input placeholder="Exercise name" @bind="newExerciseName" />
            <br /><br />
            <button class="add-btn" @onclick="AddExerciseToTemplate">
                Add
            </button>
            <button class="undo-btn" @onclick="CloseExerciseModal">
                Cancel
            </button>

        </div>
    </div>
}

@code {

    List<WorkoutSession>? templates;
    List<Exercise> allExercises = new();

    // Variabler för att skapa ny mall
    string newTemplateName = "";
    string createMessage = "";

    // Variabler för övningssökning i modal
    bool showExerciseModal = false;
    int activeTemplateId = 0;
    HashSet<int> selectedExerciseIds = new();
    Dictionary<int, string> selectedExercises = new();
    string exerciseSearch = "";
    string newExerciseName = "";

    ApplicationUser? user;

    bool EnsureUser()
    {
        if (user == null || string.IsNullOrEmpty(user.Id))
        {
            nav.NavigateTo("/login");
            return false;
        }
        return true;
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();

        if (authState.User?.Identity?.IsAuthenticated != true)
        {
            nav.NavigateTo("/login");
            return;
        }

        user = await userManager.GetUserAsync(authState.User);

        var userId = user?.Id;

        if (string.IsNullOrEmpty(userId))
        {
            nav.NavigateTo("/login");
            return;
        }

        await LoadTemplates();

        // Hämta alla övningar för sökmodalen
        allExercises = await db.Exercises
            .OrderBy(e => e.Name)
            .ToListAsync();
    }

    // Hämtar alla mallar med övningar
    async Task LoadTemplates()
    {
        if (user == null || string.IsNullOrEmpty(user.Id))
        {
            templates = new List<WorkoutSession>();
            return;
        }

        try
        {
            templates = await db.WorkoutSessions
                .Include(w => w.WorkoutExercises)
                .ThenInclude(we => we.Exercise)
                .Where(w => w.UserId == user.Id && w.IsTemplate)
                .OrderBy(w => w.Title)
                .ToListAsync();
        }
        catch
        {
            templates = new List<WorkoutSession>();
        }
    }

    // Skapar en ny tom mall
    async Task CreateTemplate()
    {
        if (string.IsNullOrWhiteSpace(newTemplateName))
        {
            createMessage = "Name required";
            return;
        }

        var template = new WorkoutSession
        {
            UserId = user!.Id,
            Title = newTemplateName.Trim(),
            Date = DateTime.Today,
            CreatedAt = DateTime.Now,
            IsTemplate = true
        };

        db.WorkoutSessions.Add(template);
        await db.SaveChangesAsync();

        newTemplateName = "";
        createMessage = "Template created!";

        await LoadTemplates();
    }

    // Öppnar modal för att lägga till övning i en specifik mall
    void OpenExerciseModal(int templateId)
    {
        activeTemplateId = templateId;
        showExerciseModal = true;
        exerciseSearch = "";
        selectedExerciseIds = new();
        selectedExercises = new();
        newExerciseName = "";
    }

    // Stänger modal och nollställer state
    void CloseExerciseModal()
    {
        showExerciseModal = false;
        activeTemplateId = 0;
        exerciseSearch = "";
        selectedExerciseIds = new();
        selectedExercises = new();
        newExerciseName = "";
    }

    // Filtrerar övningar vid varje knapptryckning
    void OnExerciseSearch(ChangeEventArgs e)
    {
        exerciseSearch = e.Value?.ToString() ?? "";
    }

    // Väljer en övning från sökresultaten
    void SelectExercise(Exercise ex)
    {
        if (selectedExerciseIds.Contains(ex.Id))
        {
            selectedExerciseIds.Remove(ex.Id);
            selectedExercises.Remove(ex.Id);
        }
        else
        {
            selectedExerciseIds.Add(ex.Id);
            selectedExercises[ex.Id] = ex.Name;
        }
    }
    // Lägger till övning i aktiv mall
    async Task AddExerciseToTemplate()
    {
        if (activeTemplateId == 0) return;

        // Lägg till alla förbockade övningar
        foreach (var id in selectedExerciseIds)
        {
            var exercise = db.Exercises.FirstOrDefault(e => e.Id == id);
            if (exercise == null) continue;

            db.WorkoutExercises.Add(new WorkoutExercise
            {
                WorkoutSessionId = activeTemplateId,
                ExerciseId = exercise.Id
            });
        }

        // Skapa och lägg till ny övning om namn angivits
        if (!string.IsNullOrWhiteSpace(newExerciseName))
        {
            var newExercise = new Exercise { Name = newExerciseName.Trim() };
            db.Exercises.Add(newExercise);
            await db.SaveChangesAsync();

            allExercises = await db.Exercises.OrderBy(e => e.Name).ToListAsync();

            db.WorkoutExercises.Add(new WorkoutExercise
            {
                WorkoutSessionId = activeTemplateId,
                ExerciseId = newExercise.Id
            });
        }

        await db.SaveChangesAsync();
        CloseExerciseModal();
        await LoadTemplates();
    }

    // Tar bort en övning från en mall
    async Task RemoveExerciseFromTemplate(int workoutExerciseId, int templateId)
    {
        var we = db.WorkoutExercises.FirstOrDefault(x => x.Id == workoutExerciseId);

        if (we != null)
        {
            db.WorkoutExercises.Remove(we);
            await db.SaveChangesAsync();
        }

        await LoadTemplates();
    }

    // Skapar ett nytt träningspass baserat på vald mall
    async Task UseTemplate(int templateId)
    {
        var template = await db.WorkoutSessions
            .Include(w => w.WorkoutExercises)
            .FirstOrDefaultAsync(w => w.Id == templateId);

        if (template == null) return;

        // Skapa nytt pass med mallens titel och dagens datum
        var newSession = new WorkoutSession
        {
            UserId = user!.Id,
            Title = template.Title,
            Date = DateTime.Today,
            CreatedAt = DateTime.Now,
            IsTemplate = false
        };

        db.WorkoutSessions.Add(newSession);
        await db.SaveChangesAsync();

        // Kopiera övningar från mallen till det nya passet
        foreach (var we in template.WorkoutExercises)
        {
            db.WorkoutExercises.Add(new WorkoutExercise
            {
                WorkoutSessionId = newSession.Id,
                ExerciseId = we.ExerciseId
            });
        }

        await db.SaveChangesAsync();

        // Navigera direkt till det nya passet
        nav.NavigateTo($"/workout/{newSession.Id}");
    }

    // Raderar en mall
    async Task DeleteTemplate(int templateId)
    {
        var template = await db.WorkoutSessions
            .Include(w => w.WorkoutExercises)
            .FirstOrDefaultAsync(w => w.Id == templateId);

        if (template != null)
        {
            db.WorkoutSessions.Remove(template);
            await db.SaveChangesAsync();
        }

        await LoadTemplates();
    }

}