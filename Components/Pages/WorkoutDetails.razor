@page "/workout/{id:int}"
@attribute [Authorize]
@rendermode InteractiveServer

@using GymTracker.Data
@using GymTracker.Models
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Identity
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.EntityFrameworkCore
@using System.Linq

@inject ApplicationDbContext db
@inject UserManager<ApplicationUser> userManager
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager nav
@inject IJSRuntime JS

@if (workout == null)
{
    <p>Loading...</p>
}
else
{
    <div class="workout-top">

        <button class="undo-btn back-btn" @onclick="GoBack">Back</button>

    </div>

    <div class="workout-header">

        <h2>@workout.Title</h2>

        <div class="workout-meta">
            <span>@workout.Date.ToShortDateString()</span>
            @if (workout.IsTemplate)
            {
                <span class="template-badge">Template</span>
            }
        </div>

        @if (!string.IsNullOrWhiteSpace(workout.Notes))
        {
            <p class="notes">Notes: @workout.Notes</p>
        }

        <div class="workout-stats">
            <span>@workout.WorkoutExercises.Count exercises</span>
            <span>@workout.WorkoutExercises.SelectMany(x => x.Sets).Count() sets</span>
        </div>

        <!-- Spara detta pass som mall -->
        @if (!workout.IsTemplate)
        {
            <button class="add-btn" @onclick="SaveAsTemplate">
                Save as template
            </button>
        }

        <!-- Använd en mall för att lägga till övningar -->
        @if (templates.Any())
        {
            <div class="template-select-row">

                <select @bind="selectedTemplateId">
                    <option value="0">Use template...</option>
                    @foreach (var t in templates)
                    {
                        <option value="@t.Id">@t.Title</option>
                    }
                </select>

                @if (selectedTemplateId != 0)
                {
                    <button class="add-btn small" @onclick="ApplyTemplate">
                        Apply
                    </button>
                }

            </div>
        }

        <button class="add-btn big" @onclick="OpenExerciseModal">
            Add exercise
        </button>

    </div>

    <h4 class="section-title">Exercises</h4>

    @if (!workout.WorkoutExercises.Any())
    {
        <p class="empty">No exercises yet</p>
    }
    else
    {
        <div class="exercise-grid">
            @foreach (var we in workout.WorkoutExercises)
            {
                <div class="exercise-card">

                    <div class="exercise-header">
                        <h5>@we.Exercise?.Name</h5>

                        <button class="undo-btn small" @onclick="() => DeleteExercise(we.Id)">
                            Delete
                        </button>
                    </div>

                    @if (!we.Sets.Any())
                    {
                        <p class="empty">No sets yet</p>
                    }
                    else
                    {
                        <table class="sets-table">

                            <thead>
                                <tr>
                                    <th>Set</th>
                                    <th>Repetitions</th>
                                    <th>Weight</th>
                                </tr>
                            </thead>

                            <tbody>
                                @{
                                    int index = 1;
                                }

                                @foreach (var s in we.Sets)
                                {
                                    <tr>
                                        <td>#@index</td>
                                        <td>@s.Reps</td>
                                        <td>@s.Weight kg</td>
                                    </tr>

                                    index++;
                                }
                            </tbody>

                        </table>
                    }

                    @if (activeSetExerciseId == we.Id)
                    {
                        <div class="add-set-row">

                            <input type="number" placeholder="Reps" @bind="newReps" />

                            <input type="number" placeholder="Weight" @bind="newWeight" />

                            <button class="add-btn small" @onclick="() => SaveSet(we.Id)">
                                Save
                            </button>

                            <button class="undo-btn small" @onclick="CancelSet">
                                Cancel
                            </button>

                        </div>
                    }
                    else
                    {
                        <button class="add-btn small" @onclick="() => StartAddSet(we.Id)">
                            Add set
                        </button>
                    }

                    <div class="media-upload">

                        <div class="file-upload">

                            <!-- InputFile är helt dold, triggas via JS för att undvika native styling -->
                            <InputFile id="@($"fileInput_{we.Id}")" OnChange="(e) => UploadMedia(e, we.Id)" style="display:none" />

                            <!-- Egen knapp som triggar filväljaren via JS interop -->
                            <button class="add-btn small" @onclick="() => TriggerFileInput(we.Id)">
                                Add media
                            </button>

                        </div>

                        <!-- Note och Upload visas bara när en fil är vald för detta exercise -->
                        @if (activeMediaExerciseId == we.Id)
                        {
                            <InputText placeholder="Note..." @bind-Value="mediaNote" class="media-note-input" />

                            <button class="add-btn" @onclick="() => SaveMedia(we.Id)">
                                Upload
                            </button>
                        }

                    </div>

                    <!-- Mediagrid med bild/video, note, radera-knapp och klick för förstoring -->
                    <div class="media-grid">

                        @foreach (var media in we.Media)
                        {
                            <div class="media-item">

                                @if (media.MediaType == "image")
                                {
                                    <!-- Klick på bilden öppnar lightbox -->
                                    <img src="@media.FilePath" @onclick="() => OpenLightbox(media.FilePath, media.Note)"
                                         style="cursor:pointer" />
                                }
                                else
                                {
                                    <video controls>
                                        <source src="@media.FilePath">
                                    </video>
                                }

                                <p class="media-note">@media.Note</p>

                                <!-- Radera-knapp för enskild mediafil -->
                                <button class="undo-btn small" @onclick="() => DeleteMedia(media.Id, media.FilePath)">
                                    Delete
                                </button>

                            </div>
                        }

                    </div>

                </div>
            }
        </div>
    }
}

<!-- Lightbox modal för förstoring av bild -->
@if (lightboxOpen)
{
    <div class="lightbox-backdrop" @onclick="CloseLightbox">

        <div class="lightbox-content" @onclick:stopPropagation>

            <img src="@lightboxSrc" />

            @if (!string.IsNullOrWhiteSpace(lightboxNote))
            {
                <p class="lightbox-note">@lightboxNote</p>
            }

            <button class="undo-btn" @onclick="CloseLightbox">Close</button>

        </div>

    </div>
}

@if (showExerciseModal)
{
    <div class="modal-backdrop">

        <div class="modal-box">

            <h3>Add exercise</h3>

            <!-- Sökruta som filtrerar övningar i realtid -->
            <input type="text" placeholder="Search exercises..." value="@exerciseSearch" @oninput="OnExerciseSearch"
                   class="search-input" />

            <!-- Filtrerad lista visas när man skrivit något -->
            @if (!string.IsNullOrWhiteSpace(exerciseSearch))
            {
                <div class="exercise-search-results">

                    @foreach (var ex in allExercises.Where(e =>
                                            e.Name.Contains(exerciseSearch, StringComparison.OrdinalIgnoreCase)))
                    {
                        <div class="exercise-search-item @(selectedExerciseId == ex.Id ? "selected" : "")"
                             @onclick="() => SelectExercise(ex)">
                            @ex.Name
                        </div>
                    }

                </div>
            }

            <!-- Visar vald övning -->
            @if (selectedExerciseId != 0)
            {
                <p class="selected-exercise-label">✓ @selectedExerciseName</p>
            }

            <br />

            <b>or create new</b>

            <InputText @bind-Value="newExerciseName" placeholder="Exercise name" />

            <br /><br />

            <button class="add-btn" @onclick="AddExerciseToWorkout">
                Add
            </button>

            <button class="undo-btn" @onclick="CloseExerciseModal">
                Cancel
            </button>

        </div>

    </div>
}

@code {

    List<Exercise> allExercises = new();

    int selectedExerciseId = 0;
    string newExerciseName = "";

    [Parameter] public int id { get; set; }

    WorkoutSession? workout;

    bool showExerciseModal = false;

    int activeSetExerciseId = 0;
    int newReps = 0;
    double newWeight = 0;

    // Variabler för filuppladdning
    IBrowserFile? selectedFile;
    string mediaNote = "";
    int activeMediaExerciseId = 0;

    // Variabler för lightbox (förstorad bild)
    bool lightboxOpen = false;
    string lightboxSrc = "";
    string lightboxNote = "";

    // Variabler för mallhantering
    List<WorkoutSession> templates = new();
    int selectedTemplateId = 0;

    ApplicationUser? user;


    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        user = await userManager.GetUserAsync(authState.User);

        workout = db.WorkoutSessions
            .Include(w => w.WorkoutExercises)
            .ThenInclude(we => we.Exercise)
            .Include(w => w.WorkoutExercises)
            .ThenInclude(we => we.Sets)
            .Include(w => w.WorkoutExercises)
            .ThenInclude(we => we.Media)
            .FirstOrDefault(w => w.Id == id && w.UserId == user!.Id);

        if (workout == null)
        {
            nav.NavigateTo("/dashboard");
            return;
        }

        allExercises = db.Exercises
            .OrderBy(e => e.Name)
            .ToList();

        // Hämta användarens mallar för dropdown
        templates = await db.WorkoutSessions
            .Include(w => w.WorkoutExercises)
            .Where(w => w.UserId == user!.Id && w.IsTemplate)
            .OrderBy(w => w.Title)
            .ToListAsync();
    }


    void GoBack()
    {
        nav.NavigateTo("/dashboard");
    }

    void OpenExerciseModal()
    {
        showExerciseModal = true;
    }

    void CloseExerciseModal()
    {
        showExerciseModal = false;
        exerciseSearch = "";
        selectedExerciseId = 0;
        selectedExerciseName = "";
    }

    // Sparar detta träningspass som en mall
    async Task SaveAsTemplate()
    {
        if (workout == null) return;

        // Skapa en ny mall baserad på detta pass
        var template = new WorkoutSession
        {
            UserId = user!.Id,
            Title = workout.Title,
            Date = DateTime.Today,
            CreatedAt = DateTime.Now,
            IsTemplate = true
        };

        db.WorkoutSessions.Add(template);
        await db.SaveChangesAsync();

        // Kopiera övningar från passet till mallen
        foreach (var we in workout.WorkoutExercises)
        {
            db.WorkoutExercises.Add(new WorkoutExercise
            {
                WorkoutSessionId = template.Id,
                ExerciseId = we.ExerciseId
            });
        }

        await db.SaveChangesAsync();

        // Uppdatera malldropdown
        templates = await db.WorkoutSessions
            .Include(w => w.WorkoutExercises)
            .Where(w => w.UserId == user!.Id && w.IsTemplate)
            .OrderBy(w => w.Title)
            .ToListAsync();

        await InvokeAsync(StateHasChanged);
    }

    // Applicerar vald mall på detta träningspass
    async Task ApplyTemplate()
    {
        if (selectedTemplateId == 0 || workout == null) return;

        var template = await db.WorkoutSessions
            .Include(w => w.WorkoutExercises)
            .FirstOrDefaultAsync(w => w.Id == selectedTemplateId);

        if (template == null) return;

        // Hämta redan tillagda övnings-IDs för att undvika dubletter
        var existingExerciseIds = workout.WorkoutExercises
            .Select(we => we.ExerciseId)
            .ToHashSet();

        foreach (var we in template.WorkoutExercises)
        {
            // Lägg bara till övningar som inte redan finns i passet
            if (!existingExerciseIds.Contains(we.ExerciseId))
            {
                db.WorkoutExercises.Add(new WorkoutExercise
                {
                    WorkoutSessionId = workout.Id,
                    ExerciseId = we.ExerciseId
                });
            }
        }

        await db.SaveChangesAsync();

        selectedTemplateId = 0;

        await ReloadWorkout();
    }

    // Triggar den dolda InputFile via JS interop
    async Task TriggerFileInput(int weId)
    {
        await JS.InvokeVoidAsync("triggerFileInput", $"fileInput_{weId}");
    }

    // Sparar vald fil och markerar vilket exercise som är aktivt
    void UploadMedia(InputFileChangeEventArgs e, int weId)
    {
        selectedFile = e.File;
        activeMediaExerciseId = weId;
    }

    // Sparar filen till disk och postar till databasen
    async Task SaveMedia(int workoutExerciseId)
    {
        if (selectedFile == null) return;

        var fileName = Guid.NewGuid() + Path.GetExtension(selectedFile.Name);

        var path = Path.Combine(
            "wwwroot/uploads/exercises",
            fileName);

        using var stream = new FileStream(path, FileMode.Create);

        await selectedFile.OpenReadStream(50000000).CopyToAsync(stream);

        var media = new ExerciseMedia
        {
            WorkoutExerciseId = workoutExerciseId,
            FilePath = "/uploads/exercises/" + fileName,
            MediaType = selectedFile.ContentType.StartsWith("video")
                ? "video"
                : "image",
            Note = mediaNote
        };

        db.ExerciseMedia.Add(media);
        await db.SaveChangesAsync();

        await ReloadWorkout();

        // Återställ uppladdningsstate
        mediaNote = "";
        selectedFile = null;
        activeMediaExerciseId = 0;
    }

    // Raderar en mediafil från databasen och disk
    async Task DeleteMedia(int mediaId, string filePath)
    {
        var media = db.ExerciseMedia.FirstOrDefault(m => m.Id == mediaId);

        if (media != null)
        {
            db.ExerciseMedia.Remove(media);
            await db.SaveChangesAsync();
        }

        // Ta bort filen från disk om den finns
        var diskPath = Path.Combine("wwwroot", filePath.TrimStart('/'));

        if (File.Exists(diskPath))
            File.Delete(diskPath);

        await ReloadWorkout();
    }

    // Öppnar lightbox med vald bild och note
    void OpenLightbox(string src, string note)
    {
        lightboxSrc = src;
        lightboxNote = note;
        lightboxOpen = true;
    }

    // Stänger lightbox
    void CloseLightbox()
    {
        lightboxOpen = false;
        lightboxSrc = "";
        lightboxNote = "";
    }

    // Variabler för övningssökning i modal
    string exerciseSearch = "";
    string selectedExerciseName = "";

    void OnExerciseSearch(ChangeEventArgs e)
    {
        exerciseSearch = e.Value?.ToString() ?? "";
        // Nollställ val om man börjar söka igen
        selectedExerciseId = 0;
        selectedExerciseName = "";
    }

    void SelectExercise(Exercise ex)
    {
        selectedExerciseId = ex.Id;
        selectedExerciseName = ex.Name;
        exerciseSearch = "";
    }


    async Task AddExerciseToWorkout()
    {
        Exercise? exercise = null;

        if (selectedExerciseId != 0)
            exercise = db.Exercises.FirstOrDefault(e => e.Id == selectedExerciseId);

        if (!string.IsNullOrWhiteSpace(newExerciseName))
        {
            exercise = new Exercise { Name = newExerciseName };

            db.Exercises.Add(exercise);

            await db.SaveChangesAsync();
        }

        if (exercise == null) return;

        var workoutExercise = new WorkoutExercise
        {
            WorkoutSessionId = workout!.Id,
            ExerciseId = exercise.Id
        };

        db.WorkoutExercises.Add(workoutExercise);

        await db.SaveChangesAsync();

        await ReloadWorkout();

        showExerciseModal = false;

        newExerciseName = "";
        selectedExerciseId = 0;
        selectedExerciseName = "";
    }


    async Task DeleteExercise(int workoutExerciseId)
    {
        var we = db.WorkoutExercises
            .Include(x => x.Sets)
            .FirstOrDefault(x => x.Id == workoutExerciseId);

        if (we != null)
        {
            db.WorkoutExercises.Remove(we);
            await db.SaveChangesAsync();
        }

        await ReloadWorkout();
    }


    void StartAddSet(int workoutExerciseId)
    {
        activeSetExerciseId = workoutExerciseId;

        newReps = 0;
        newWeight = 0;
    }


    void CancelSet()
    {
        activeSetExerciseId = 0;
    }


    async Task SaveSet(int workoutExerciseId)
    {
        if (newReps <= 0) return;

        var set = new SetEntry
        {
            WorkoutExerciseId = workoutExerciseId,
            Reps = newReps,
            Weight = newWeight
        };

        db.Sets.Add(set);

        await db.SaveChangesAsync();

        activeSetExerciseId = 0;

        await ReloadWorkout();
    }


    async Task ReloadWorkout()
    {
        workout = db.WorkoutSessions
            .Include(w => w.WorkoutExercises)
            .ThenInclude(we => we.Exercise)
            .Include(w => w.WorkoutExercises)
            .ThenInclude(we => we.Sets)
            .Include(w => w.WorkoutExercises)
            .ThenInclude(we => we.Media)
            .FirstOrDefault(w => w.Id == workout!.Id);

        await InvokeAsync(StateHasChanged);
    }

}
